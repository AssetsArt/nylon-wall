# ── Build stage ──────────────────────────────────────────
FROM rust:1.93-bookworm AS builder

RUN rustup target add wasm32-unknown-unknown
RUN cargo install dioxus-cli

WORKDIR /app

# Copy entire workspace (daemon sources needed for workspace resolution)
COPY Cargo.toml Cargo.lock ./
COPY nylon-wall-common/ nylon-wall-common/
COPY nylon-wall-ui/ nylon-wall-ui/
COPY nylon-wall-daemon/Cargo.toml nylon-wall-daemon/Cargo.toml
COPY nylon-wall-daemon/src/ nylon-wall-daemon/src/

# Build UI (produces dist/ with static assets)
WORKDIR /app/nylon-wall-ui
RUN dx build --release

# ── Runtime stage ────────────────────────────────────────
FROM nginx:alpine

COPY --from=builder /app/target/dx/nylon-wall-ui/release/web/public/ /usr/share/nginx/html/
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 8080
